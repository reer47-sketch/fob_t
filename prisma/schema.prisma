generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  status         TenantStatus    @default(ACTIVE)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  shopCode       String?         @unique @map("shop_code")
  address        String?
  animals        Animal[]
  blogs          Blog[]
  calendarTasks  CalendarTask[]
  customers      Customer[]
  labelTemplates LabelTemplate[]
  pairings       Pairing[]
  tenantCodes    TenantCode[]
  users          User[]
  zones            Zone[]
  marketListings   MarketListing[]
  marketInquiries  MarketInquiry[]  @relation("BuyerInquiries")

  @@map("tenants")
}

model User {
  id                   String     @id
  email                String     @unique
  role                 UserRole
  status               UserStatus @default(PENDING)
  name                 String?
  phone                String?
  approvedAt           DateTime?  @map("approved_at") @db.Timestamptz(6)
  approvedById         String?    @map("approved_by_id")
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  rejectionReason      String?    @map("rejection_reason")
  tenantId             String?    @map("tenant_id")
  updatedAt            DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  profileImage         String?    @map("profile_image")
  agreedAt             DateTime?  @map("agreed_at") @db.Timestamptz(6)
  dataCollectionAgreed Boolean    @default(false) @map("data_collection_agreed")
  marketingAgreed      Boolean    @default(false) @map("marketing_agreed")
  privacyAgreed        Boolean    @default(false) @map("privacy_agreed")
  termsAgreed          Boolean    @default(false) @map("terms_agreed")
  plan                 UserPlan   @default(FREE)
  planUpdatedAt        DateTime?  @map("plan_updated_at") @db.Timestamptz(6)
  googleAccessToken    String?    @map("google_access_token")
  googleRefreshToken   String?    @map("google_refresh_token")
  googleTokenExpiry    DateTime?  @map("google_token_expiry") @db.Timestamptz(6)
  tenant               Tenant?    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([role])
  @@map("users")
}

model Code {
  id             String       @id @default(cuid())
  category       CodeCategory
  code           String
  name           String
  description    String?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  displayOrder   Int          @default(0) @map("display_order")
  parentId       String?      @map("parent_id")
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDel          Boolean      @default(false) @map("is_del")
  scientificName String?      @map("scientific_name")
  animalCodes    AnimalCode[]
  parent         Code?        @relation("CodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Code[]       @relation("CodeHierarchy")
  tenantCodes    TenantCode[]

  @@unique([category, code, parentId])
  @@index([category])
  @@index([parentId])
  @@index([isDel])
  @@map("codes")
}

model Animal {
  id              String          @id @default(cuid())
  name            String?
  gender          Gender
  acquisitionDate DateTime        @map("acquisition_date") @db.Timestamptz(6)
  acquisitionType AcquisitionType @map("acquisition_type")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  deathDate       DateTime?       @map("death_date") @db.Timestamptz(6)
  qrCodeUrl       String?         @map("qr_code_url")
  tenantId        String          @map("tenant_id")
  uniqueId        String          @map("unique_id")
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDel           Boolean         @default(false) @map("is_del")
  isPublic        Boolean         @default(false) @map("is_public")
  isBreeding      Boolean         @default(false) @map("is_breeding")
  parentPublic    Boolean         @default(false) @map("parent_public")
  hatchDate       DateTime?       @map("hatch_date") @db.Timestamptz(6)
  bulkMeta        Json?           @map("bulk_meta")
  adoption        Adoption?
  codes           AnimalCode[]
  detail          AnimalDetail?
  images          AnimalImage[]
  parents         AnimalParent[]  @relation("AnimalParents")
  children        AnimalParent[]  @relation("ParentAnimals")
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eggsAsFemale    Egg[]           @relation("EggFemale")
  hatchedFromEgg  Egg?            @relation("HatchedFromEgg")
  eggsAsMale2     Egg[]           @relation("EggSire2")
  eggsAsMale      Egg[]           @relation("EggSire")
  feedings        Feeding[]
  pairingsFemale  Pairing[]       @relation("PairingFemale")
  pairingsMale    Pairing[]       @relation("PairingMale")
  rackCells       RackCell[]
  marketListing   MarketListing?

  @@unique([tenantId, uniqueId])
  @@index([tenantId])
  @@index([uniqueId])
  @@index([isDel])
  @@index([isPublic])
  @@index([isBreeding])
  @@map("animals")
}

model AnimalCode {
  id        String   @id @default(cuid())
  animalId  String   @map("animal_id")
  codeId    String   @map("code_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  isPrimary Boolean  @default(false) @map("is_primary")
  animal    Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  code      Code     @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@unique([animalId, codeId])
  @@index([animalId])
  @@index([codeId])
  @@index([animalId, isPrimary])
  @@map("animal_codes")
}

model AnimalDetail {
  id               String   @id @default(cuid())
  quality          Quality?
  animalId         String   @unique @map("animal_id")
  cageInfo         String?  @map("cage_info")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  currentSize      String?  @map("current_size")
  distinctiveMarks String?  @map("distinctive_marks")
  flooringInfo     String?  @map("flooring_info")
  habitatNotes     String?  @map("habitat_notes")
  healthStatus     String?  @map("health_status")
  isMating         Boolean  @default(false) @map("is_mating")
  specialNeeds     String?  @map("special_needs")
  tailStatus       String?  @map("tail_status")
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  patternType      String?  @map("pattern_type")
  animal           Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("animal_details")
}

model AnimalParent {
  id         String     @id @default(cuid())
  animalId   String     @map("animal_id")
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  parentId   String     @map("parent_id")
  parentType ParentType @map("parent_type")
  isPublic   Boolean    @default(false) @map("is_public")
  animal     Animal     @relation("AnimalParents", fields: [animalId], references: [id], onDelete: Cascade)
  parent     Animal     @relation("ParentAnimals", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([animalId, parentId])
  @@index([animalId])
  @@index([parentId])
  @@index([isPublic])
  @@map("animal_parents")
}

model AnimalImage {
  id           String   @id @default(cuid())
  description  String?
  animalId     String   @map("animal_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  displayOrder Int      @default(0) @map("display_order")
  imageUrl     String   @map("image_url")
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  animal       Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId])
  @@map("animal_images")
}

model Feeding {
  id          Int      @id @default(autoincrement())
  animalId    String   @map("animal_id")
  foodType    FoodType @map("food_type")
  feedingDate DateTime @map("feeding_date") @db.Timestamptz(6)
  quantity    String?
  memo        String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  superfood   Boolean  @default(false)
  animal      Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId])
  @@index([feedingDate])
  @@map("feedings")
}

model Customer {
  id             String     @id @default(cuid())
  tenantId       String     @map("tenant_id")
  name           String
  phone          String
  address        String?
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  isDel          Boolean    @default(false) @map("is_del")
  privacyConsent Boolean    @default(false) @map("privacy_consent")
  adoptions      Adoption[]
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([phone])
  @@map("customers")
}

model Adoption {
  id              String   @id @default(cuid())
  customerId      String   @map("customer_id")
  animalId        String   @unique @map("animal_id")
  adoptionDate    DateTime @map("adoption_date") @db.Timestamptz(6)
  price           Int
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  isReported      Boolean  @default(false) @map("is_reported")
  transferPurpose String?  @map("transfer_purpose")
  transferReason  String?  @map("transfer_reason")
  animal          Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([animalId])
  @@index([adoptionDate])
  @@map("adoptions")
}

model LabelTemplate {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  content   Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("label_templates")
}

model Blog {
  id           String       @id @default(cuid())
  tenantId     String       @map("tenant_id")
  title        String
  slug         String       @unique
  content      Json
  htmlContent  String?      @map("html_content")
  thumbnailUrl String?      @map("thumbnail_url")
  isNotice     Boolean      @default(false) @map("is_notice")
  targetScope  TargetScope  @default(ALL) @map("target_scope")
  views        Int          @default(0)
  publishedAt  DateTime     @default(now()) @map("published_at") @db.Timestamptz(6)
  expiredAt    DateTime?    @map("expired_at") @db.Timestamptz(6)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  attachments  Attachment[]
  tags         BlogTag[]
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([publishedAt, targetScope])
  @@map("blogs")
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  blogs BlogTag[]

  @@map("tags")
}

model BlogTag {
  blogId String @map("blog_id")
  tagId  String @map("tag_id")
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
  @@map("blog_tags")
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileSize  Int      @map("file_size")
  mimeType  String   @map("mime_type")
  blogId    String   @map("blog_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Banner {
  id           String    @id @default(cuid())
  title        String
  imageUrl     String    @map("image_url")
  linkUrl      String?   @map("link_url")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  startDate    DateTime? @map("start_date") @db.Timestamptz(6)
  endDate      DateTime? @map("end_date") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive])
  @@index([displayOrder])
  @@index([startDate, endDate])
  @@map("banners")
}

model Zone {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  name         String
  description  String?
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  racks        Rack[]
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("zones")
}

model Rack {
  id           String     @id @default(cuid())
  zoneId       String     @map("zone_id")
  name         String
  rows         Int
  cols         Int
  displayOrder Int        @default(0) @map("display_order")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  cells        RackCell[]
  zone         Zone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@map("racks")
}

model RackCell {
  id        String   @id @default(cuid())
  rackId    String   @map("rack_id")
  row       Int
  col       Int
  animalId  String?  @map("animal_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  animal    Animal?  @relation(fields: [animalId], references: [id])
  rack      Rack     @relation(fields: [rackId], references: [id], onDelete: Cascade)

  @@unique([rackId, row, col])
  @@index([rackId])
  @@index([animalId])
  @@map("rack_cells")
}

model Pairing {
  id                String        @id @default(cuid())
  tenantId          String        @map("tenant_id")
  femaleId          String        @map("female_id")
  date              DateTime      @db.Timestamptz(6)
  status            PairingStatus @default(MATING)
  memo              String?
  doneAt            DateTime?     @map("done_at") @db.Timestamptz(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  maleId            String        @map("male_id")
  endScheduledAt    DateTime?     @map("end_scheduled_at") @db.Timestamptz(6)
  manuallyCoolingAt DateTime?     @map("manually_cooling_at") @db.Timestamptz(6)
  eggs2             Egg[]         @relation("EggPairing2")
  eggs              Egg[]         @relation("EggPairing")
  female            Animal        @relation("PairingFemale", fields: [femaleId], references: [id], onDelete: Cascade)
  male              Animal        @relation("PairingMale", fields: [maleId], references: [id], onDelete: Cascade)
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([femaleId])
  @@index([maleId])
  @@index([status])
  @@map("pairings")
}

model Egg {
  id                String           @id @default(cuid())
  pairingId         String?          @map("pairing_id")
  femaleId          String           @map("female_id")
  layDate           DateTime         @map("lay_date") @db.Timestamptz(6)
  checked           Boolean          @default(false)
  fertileStatus     FertileStatus    @default(UNKNOWN) @map("fertile_status")
  humidity          Int?
  substrate         String?
  status            EggStatus        @default(INCUBATING)
  hatchDate         DateTime?        @map("hatch_date") @db.Timestamptz(6)
  memo              String?
  hatchedAnimalId   String?          @unique @map("hatched_animal_id")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  maleId            String?          @map("male_id")
  maleId2           String?          @map("male_id_2")
  pairingId2        String?          @map("pairing_id_2")
  expectedHatchDate DateTime?        @map("expected_hatch_date") @db.Timestamptz(6)
  googleEventId     String?          @map("google_event_id")
  female            Animal           @relation("EggFemale", fields: [femaleId], references: [id], onDelete: Cascade)
  hatchedAnimal     Animal?          @relation("HatchedFromEgg", fields: [hatchedAnimalId], references: [id])
  male2             Animal?          @relation("EggSire2", fields: [maleId2], references: [id])
  male              Animal?          @relation("EggSire", fields: [maleId], references: [id], onDelete: Cascade)
  pairing2          Pairing?         @relation("EggPairing2", fields: [pairingId2], references: [id])
  pairing           Pairing?         @relation("EggPairing", fields: [pairingId], references: [id], onDelete: Cascade)
  temperatureLogs   TemperatureLog[]

  @@index([pairingId])
  @@index([pairingId2])
  @@index([femaleId])
  @@index([maleId])
  @@index([maleId2])
  @@index([status])
  @@index([layDate])
  @@map("eggs")
}

model TemperatureLog {
  id        Int      @id @default(autoincrement())
  eggId     String   @map("egg_id")
  temp      Float
  startDate DateTime @map("start_date") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  egg       Egg      @relation(fields: [eggId], references: [id], onDelete: Cascade)

  @@index([eggId])
  @@map("temperature_logs")
}

model TenantCode {
  tenantId  String   @map("tenant_id")
  codeId    String   @map("code_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  id        Int      @id @default(autoincrement())
  code      Code     @relation(fields: [codeId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, codeId])
  @@index([tenantId])
  @@index([codeId])
  @@map("tenant_codes")
}

model CalendarTask {
  id            String       @id @default(cuid())
  tenantId      String       @map("tenant_id")
  title         String
  date          DateTime     @db.Date
  completed     Boolean      @default(false)
  category      TaskCategory @default(OTHER)
  memo          String?
  googleEventId String?      @map("google_event_id")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([date])
  @@map("calendar_tasks")
}

model user_activity {
  id          Int      @id @default(autoincrement())
  user_id     String
  active_date DateTime @db.Date
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@unique([user_id, active_date])
  @@index([active_date])
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserRole {
  ADMIN
  CLIENT
  BREEDER
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
  DELETED
}

enum UserPlan {
  FREE
  PRO
  PREMIUM
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum AcquisitionType {
  ADOPTION
  HATCHING
}

enum Quality {
  S
  A
  B
  C
}

enum ParentType {
  FATHER
  MOTHER
}

enum CodeCategory {
  SPECIES
  MORPH
  TRAIT
  COLOR
  CATEGORY
}

enum FoodType {
  CRICKET
  MEALWORM
  FEED
  VEGETABLE
  MOUSE
  FROZEN_CHICK
  FRUIT_FLY
  OTHER
}

enum TargetScope {
  ALL
  MEMBER_ONLY
}

enum PairingStatus {
  WAITING
  MATING
  LAYING_SOON
  LAID
  DONE
  COOLING
}

enum EggStatus {
  INCUBATING
  HATCHED
  FAILED
}

enum FertileStatus {
  UNKNOWN
  FERTILE
  INFERTILE
}

enum TaskCategory {
  CLEANING
  RACK_SETUP
  FEEDING_PREP
  HEALTH_CHECK
  OTHER
}

// ============================================
// 마켓 분양 매물
// ============================================
model MarketListing {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  animalId    String        @unique @map("animal_id")
  title       String
  price       Int
  description String?       @db.Text
  status      ListingStatus @default(ACTIVE)
  viewCount   Int           @default(0) @map("view_count")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  animal    Animal          @relation(fields: [animalId], references: [id], onDelete: Cascade)
  inquiries MarketInquiry[]

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("market_listings")
}

// ============================================
// 마켓 구매 문의
// ============================================
model MarketInquiry {
  id            String        @id @default(cuid())
  listingId     String        @map("listing_id")
  buyerTenantId String        @map("buyer_tenant_id")
  message       String        @db.Text
  isRead        Boolean       @default(false) @map("is_read")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  listing     MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerTenant Tenant        @relation("BuyerInquiries", fields: [buyerTenantId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([buyerTenantId])
  @@map("market_inquiries")
}

enum ListingStatus {
  ACTIVE
  RESERVED
  SOLD
  WITHDRAWN
}
